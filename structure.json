{
  "log": {
    "disabled": true,
    "level": "panic"
  },
  "dns": {
    "servers": [
      {
        "tag": "Internet-dns",
        "address": "http://1.1.1.1:443/dns-query",
        "strategy": "prefer_ipv4",
        "detour": "Internet"
      },
      {
        "tag": "direct-dns",
        "address": "tcp://1.1.1.1",
        "strategy": "prefer_ipv4",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "direct-dns"
      }
    ],
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "direct",
      "mtu": 9000,
      "address": "172.18.0.1/30",
      "auto_route": true,
      "strict_route": true,
      "route_exclude_address": [
        "192.168.0.0/16",
        "fc00::/7"
      ],
      "stack": "mixed",
      "domain_strategy": "prefer_ipv4"
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Internet",
      "outbounds": ["Best Latency"]
    },
    {
      "type": "urltest",
      "tag": "Best Latency",
      "outbounds": [],
      "url": "http://1.1.1.1/",
      "interval": "3m0s",
      "tolerance": 1
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "inbound": "dns-in"
          },
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "network": "tcp",
        "port": 853,
        "action": "reject",
        "method": "default"
      },
      {
        "network": "udp",
        "port": [443, 853],
        "action": "reject",
        "method": "default"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "protocol": "stun",
        "action": "reject",
        "method": "default"
      },
      {
        "source_ip_cidr": [
          "224.0.0.0/3",
          "ff00::/8"
        ],
        "ip_cidr": [
          "224.0.0.0/3",
          "ff00::/8"
        ],
        "action": "reject",
        "method": "default"
      }
    ],
    "auto_detect_interface": true,
    "override_android_vpn": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "@SiNAVM"
    }
  }
}
